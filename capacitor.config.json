{
  "appId": "com.danieljacius.capitolkey",
  "appName": "CapitolKey",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0A1929"
  },
  "android": {
    "backgroundColor": "#0A1929"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#0A1929",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    }
  },
  "deepLinks": {
    "associatedDomains": ["applinks:capitolkey.vercel.app"],
    "pathPrefix": ["/bill/"]
  }
}
