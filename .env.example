# CapitolKey — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to git — it is already in .gitignore.

# ── Backend (set these in Railway Environment Variables) ──────────────────────
LEGISCAN_API_KEY=your_legiscan_api_key_here
CONGRESS_API_KEY=your_congress_gov_api_key_here
OPENSTATES_API_KEY=your_openstates_api_key_here
PORT=3001

# ── AI Personalization ──────────────────────────────────────────────────────
# Uses Anthropic Claude for bill personalization.
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional hourly cap for Anthropic API calls (default: unlimited)
# ANTHROPIC_HOURLY_CAP=100

# ── Groq (optional fallback LLM) ──────────────────────────────────────────
# If set, Groq is used as primary LLM; Claude as fallback.
# GROQ_API_KEY=your_groq_api_key_here

# ── Supabase (persistent cache for AI personalizations) ──────────────────────
# Get these from your Supabase project: Settings → API
# Without these, the server falls back to in-memory caching.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Resend (email notifications for bill status changes) ─────────────────────
# Get your API key from https://resend.com/api-keys
# Without this, email notifications are disabled (push can still work).
RESEND_API_KEY=re_your_api_key_here

# ── Firebase Cloud Messaging (push notifications for native app) ─────────────
# Paste the full JSON content of your Firebase service account key file here.
# Get it from Firebase Console → Project Settings → Service accounts → Generate new private key
# Without this, push notifications are disabled (email can still work).
# Also add google-services.json to android/app/ and GoogleService-Info.plist to iOS.
FCM_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}

# ── Admin ──────────────────────────────────────────────────────────────────
# Secret token for /api/admin/* endpoints. Required in production.
ADMIN_SECRET=your_admin_secret_here

# The origin of your deployed frontend (no trailing slash).
# Railway uses this to restrict CORS to your actual frontend domain.
FRONTEND_URL=https://your-frontend-domain.com

# ── Frontend (set in Vercel / Netlify / wherever you deploy the React app) ────
# Full URL of your Railway backend (no trailing slash).
# Leave blank in local dev — Vite's proxy handles /api/* automatically.
VITE_API_BASE_URL=https://your-railway-backend.up.railway.app

# ── Supabase Auth (optional — enables user accounts on the frontend) ──────────
# Get these from your Supabase project: Settings → API
# Without these, the app works fully in anonymous mode (no login).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Sentry (error tracking — optional) ──────────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
# Without this, error tracking is silently disabled.
VITE_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/1234567

# ── Sign in with Apple (Supabase dashboard setup required) ──────────────────
# The frontend code + iOS entitlement are ready, but you must also:
#   1. Enable Apple provider in Supabase: Authentication → Providers → Apple
#   2. Enter your Apple Team ID + Services ID (from developer.apple.com)
#   3. Add the Supabase callback URL to your Apple Services ID config
# Without this, the Apple sign-in button will error at runtime.
