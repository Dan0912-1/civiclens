# CivicLens — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to git — it is already in .gitignore.

# ── Backend (set these in Railway Environment Variables) ──────────────────────
CONGRESS_API_KEY=your_congress_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001

# The origin of your deployed frontend (no trailing slash).
# Railway uses this to restrict CORS to your actual frontend domain.
FRONTEND_URL=https://your-frontend-domain.com

# ── Frontend (set in Vercel / Netlify / wherever you deploy the React app) ────
# Full URL of your Railway backend (no trailing slash).
# Leave blank in local dev — Vite's proxy handles /api/* automatically.
VITE_API_BASE_URL=https://your-railway-backend.up.railway.app
