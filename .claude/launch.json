{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host", "127.0.0.1"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Backend (Express API)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--env-file=.env", "api/server.js"],
      "port": 3001
    },
    {
      "name": "Frontend + Backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    }
  ]
}
